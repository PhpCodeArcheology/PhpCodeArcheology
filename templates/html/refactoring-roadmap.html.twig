{% include('@Parts/header.html.twig') %}

<div class="mt-6 lg:w-5/6">
  <div class="mb-7 text-sm">
    <ul class="flex gap-1">
      <li class="flex after:content-['⮁'] gap-1">
        <a href="index.html" class="text-cyan-500">Home</a>
      </li>
      <li>Refactoring Roadmap</li>
    </ul>
  </div>

  <h1 class="mb-6 text-3xl font-semibold font-display">Refactoring Roadmap</h1>

  {# Summary Cards #}
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Classes Needing Attention</div>
      <div style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500;
        {% if classesNeedingRefactoring > totalClasses * 0.5 %}color: #fca5a5{% elseif classesNeedingRefactoring > totalClasses * 0.2 %}color: #fde68a{% else %}color: #86efac{% endif %}">
        {{ classesNeedingRefactoring }}
      </div>
      <div style="font-size: 0.7rem; color: rgba(255,255,255,0.4);">of {{ totalClasses }} classes</div>
    </div>
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Avg. Priority</div>
      <div style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500;">{{ avgPriority|number_format(1) }}</div>
    </div>
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Highest Priority</div>
      <div style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500;
        {% if maxPriority >= 75 %}color: #fca5a5{% elseif maxPriority >= 50 %}color: #fde68a{% else %}color: #86efac{% endif %}">
        {{ maxPriority|number_format(1) }}
      </div>
    </div>
  </div>

  {# Score Distribution Chart #}
  <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-6 mb-6">
    <h2 class="font-display text-sm uppercase tracking-wider text-cyan-600/60 mb-4">Score Distribution</h2>
    <div style="height: 200px; position: relative;">
      <canvas id="distributionChart"></canvas>
    </div>
  </div>

  {# Ranked Table #}
  {% if refactoringPriorities|length > 0 %}
  <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-6 mb-6">
    <h2 class="font-display text-sm uppercase tracking-wider text-cyan-600/60 mb-4">Priority Ranking</h2>

    <div class="mb-4">
      <input type="text" id="filterInput" placeholder="Filter classes..."
        class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-cyan-500">
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="roadmapTable">
        <thead>
          <tr class="border-b border-zinc-700 text-left text-zinc-400">
            <th class="px-3 py-2 w-10">#</th>
            <th class="px-3 py-2 cursor-pointer hover:text-white" data-sort="text">Class</th>
            <th class="px-3 py-2 cursor-pointer hover:text-white text-right" data-sort="num">Score</th>
            <th class="px-3 py-2">Drivers</th>
            <th class="px-3 py-2 cursor-pointer hover:text-white text-right" data-sort="num">CC</th>
            <th class="px-3 py-2 cursor-pointer hover:text-white text-right" data-sort="num">LCOM</th>
            <th class="px-3 py-2 cursor-pointer hover:text-white text-right" data-sort="num">LLOC</th>
            <th class="px-3 py-2 cursor-pointer hover:text-white text-right" data-sort="num">Dependents</th>
            <th class="px-3 py-2">Recommendation</th>
          </tr>
        </thead>
        <tbody>
          {% for i, entry in refactoringPriorities %}
          <tr class="border-b border-zinc-800/50 hover:bg-cyan-950/30" data-filter="{{ entry.fullName|lower }}">
            <td class="px-3 py-2 text-zinc-500">{{ i + 1 }}</td>
            <td class="px-3 py-2">
              <a href="classes/{{ entry.id }}.html" class="text-cyan-400 hover:text-cyan-300">{{ entry.name }}</a>
              {% if entry.fullName != entry.name %}
                <div class="text-xs text-zinc-500">{{ entry.fullName }}</div>
              {% endif %}
            </td>
            <td class="px-3 py-2 text-right">
              <span class="inline-block px-2 py-0.5 rounded text-xs font-bold
                {% if entry.score >= 75 %}bg-red-900/50 text-red-300
                {% elseif entry.score >= 50 %}bg-orange-900/50 text-orange-300
                {% elseif entry.score >= 25 %}bg-yellow-900/50 text-yellow-300
                {% else %}bg-cyan-900/50 text-cyan-300{% endif %}">
                {{ entry.score|number_format(1) }}
              </span>
            </td>
            <td class="px-3 py-2">
              <div class="flex flex-wrap gap-1">
                {% for driver in entry.drivers %}
                  <span class="inline-block px-1.5 py-0.5 rounded text-[0.65rem]
                    {% if driver == 'high complexity' or driver == 'dependency cycle' %}bg-red-900/40 text-red-300
                    {% elseif driver == 'low cohesion' or driver == 'SOLID violations' %}bg-orange-900/40 text-orange-300
                    {% elseif driver == 'many issues' or driver == 'excessive size' %}bg-yellow-900/40 text-yellow-300
                    {% else %}bg-zinc-700/50 text-zinc-300{% endif %}">
                    {{ driver }}
                  </span>
                {% endfor %}
              </div>
            </td>
            <td class="px-3 py-2 text-right {% if entry.cc > 20 %}text-red-400{% elseif entry.cc > 10 %}text-yellow-400{% else %}text-zinc-400{% endif %}">{{ entry.cc }}</td>
            <td class="px-3 py-2 text-right {% if entry.lcom > 5 %}text-red-400{% elseif entry.lcom > 2 %}text-yellow-400{% else %}text-zinc-400{% endif %}">{{ entry.lcom }}</td>
            <td class="px-3 py-2 text-right text-zinc-400">{{ entry.lloc }}</td>
            <td class="px-3 py-2 text-right text-zinc-400">{{ entry.usedFromOutsideCount }}</td>
            <td class="px-3 py-2 text-zinc-500 text-xs max-w-xs" data-tooltip="{{ entry.recommendation }}">
              {{ entry.recommendation|length > 80 ? entry.recommendation[:80] ~ '...' : entry.recommendation }}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% else %}
  <div class="rounded-xl border border-green-800 bg-green-950/30 p-8 text-center mb-6">
    <div style="font-size: 2rem; margin-bottom: 0.5rem;">&#10003;</div>
    <h2 class="text-xl font-semibold text-green-300 mb-2">No refactoring needed</h2>
    <p class="text-zinc-400">All classes have a clean bill of health. No refactoring priorities detected.</p>
  </div>
  {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const isLight = document.documentElement.getAttribute('data-theme') === 'light';
  Chart.defaults.color = isLight ? '#475569' : 'rgba(255,255,255,0.5)';
  Chart.defaults.font.family = "'Source Sans 3', sans-serif";

  // Distribution chart
  const dist = {{ distribution|json_encode|raw }};
  new Chart(document.getElementById('distributionChart'), {
    type: 'bar',
    data: {
      labels: ['Clean (0)', 'Low (1-25)', 'Medium (26-50)', 'High (51-75)', 'Critical (76-100)'],
      datasets: [{
        data: [dist.clean, dist.low, dist.medium, dist.high, dist.critical],
        backgroundColor: ['#065f46', '#155e75', '#854d0e', '#c2410c', '#991b1b'],
        borderColor: ['#10b981', '#06b6d4', '#eab308', '#f97316', '#ef4444'],
        borderWidth: 1,
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { precision: 0 },
          grid: { color: isLight ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.03)' }
        },
        x: {
          grid: { display: false }
        }
      }
    }
  });

  // Filter
  const filterInput = document.getElementById('filterInput');
  if (filterInput) {
    filterInput.addEventListener('input', function() {
      const term = this.value.toLowerCase();
      document.querySelectorAll('#roadmapTable tbody tr').forEach(function(row) {
        const text = row.getAttribute('data-filter') || '';
        row.style.display = text.includes(term) ? '' : 'none';
      });
    });
  }
});
</script>

{% include('@Parts/footer.html.twig') %}
