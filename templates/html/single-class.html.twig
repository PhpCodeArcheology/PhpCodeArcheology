{% include('@Parts/header.html.twig') %}
{% set metricCollectionId = class.getIdentifier().__toString() %}

<div class="mt-6 lg:w-5/6">
  <div class="mb-7 text-sm">
    <ul class="flex gap-1">
      <li class="flex after:content-['⮁'] gap-1">
        <a href="../index.html" class="text-cyan-500">Home</a>
      </li>
      <li class="flex after:content-['⮁'] gap-1">
        <a href="../classes-list.html" class="text-cyan-500">Classes</a>
      </li>
      {% if class.get('namespace').getValue() %}
      <li class="flex after:content-['⮁'] gap-1">
        <span class="text-white/50">{{ class.get('namespace') }}</span>
      </li>
      {% endif %}
      <li>{{ class.get('singleName') }}</li>
    </ul>
  </div>

  <h1 class="mb-3 text-lg font-semibold font-display">Class metrics for:</h1>
  <h2 class="mb-6 text-3xl flex justify-between gap-4 items-center">
    <div>
      <span class="text-white/40">{{ class.get('namespace') }}\</span>
      <span class="font-semibold inline-block" title="{{ class.get('namespace') }}\{{ class.get('singleName') }}">{{ class.get('singleName') }}</span>
    </div>
    {% if class.interface.getValue() %}
      <div class="rounded px-2 py-0.5 bg-amber-900 mt-0.5">Interface</div>
    {% elseif class.trait.getValue() %}
      <div class="rounded px-2 py-0.5 bg-purple-900 mt-0.5">Trait</div>
    {% elseif class.enum.getValue() %}
      <div class="rounded px-2 py-0.5 bg-emerald-900 mt-0.5">Enum</div>
    {% elseif class.abstract.getValue() %}
      <div class="rounded px-2 py-0.5 bg-fuchsia-900 mt-0.5">Abstract</div>
    {% elseif class.anonymous.getValue() %}
      <div class="rounded px-2 py-0.5 bg-gray-800 mt-0.5">Anonymous</div>
    {% else %}
      <div class="rounded px-2 py-0.5 bg-blue-900 mt-0.5">Class</div>
    {% endif %}
  </h2>

  {% set constants = class.getCollection('constants').getAsArray() %}
  <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
    <h3 class="mb-3 text-xl font-semibold font-display">Constants</h3>
    {% if constants|length > 0 %}
      <table>
        <tbody>
        {% for property in constants %}
          <tr>
            <td class="text-white/40 pr-4">{{ property.scope }}</td>
            <td class="text-lg font-semibold">{{ property.name }}</td>
            <td class="italic text-white/70 pl-4">{{ property.valueType }}</td>
            <td class="italic text-white/80 pl-4"><pre>{{ property.value }}</pre></td>
            <td class="italic text-white/60 pl-4">{{ property.comment }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="font-semibold">No constants used</p>
    {% endif %}
  </div>

  {% set properties = class.getCollection('properties').getAsArray() %}
  <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
    <h3 class="mb-3 text-xl font-semibold font-display">Properties</h3>
    {% if properties|length > 0 %}
      <table>
        <tbody>
        {% for property in properties %}
          <tr>
            <td class="text-white/40 pr-4">{{ property.scope }} {{ property.type }}{% if property.type is empty %}implicit mixed{% endif %}</td>
            <td class="text-lg font-semibold">{{ property.name }}</td>
            <td class="italic text-white/60 pl-4">{{ property.comment }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="font-semibold">No properties used</p>
    {% endif %}
  </div>

  <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
    <h3 class="mb-3 text-xl font-semibold font-display">Dependencies</h3>

    {% set extends = class.getCollection('extends').getAsArray() %}
    {% set interfaces = class.getCollection('interfaces').getAsArray() %}
    {% set traits = class.getCollection('traits').getAsArray() %}
    {% set usedClasses = class.getCollection('usedClasses').getAsArray() %}

    {% if extends|length or interfaces|length or traits|length or usedClasses|length or class.get('usedBy').getValue()|length %}
    <table class="w-full border-collapse">
      <tbody>
        {% if interfaces|length %}
          <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
            <th class="text-left p-2 align-top">Implements</th>
            <td class="p-2">{{ interfaces|sort|join('<br>')|raw }}</td>
          </tr>
        {% endif %}
        {% if extends|length %}
        <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
          <th class="text-left p-2 align-top">Extends</th>
          <td class="p-2">{{ extends|sort|join('<br>')|raw }}</td>
        </tr>
        {% endif %}
        {% if traits|length %}
          <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
            <th class="text-left p-2 align-top">Traits</th>
            <td class="p-2">{{ traits|sort|join('<br>')|raw }}</td>
          </tr>
        {% endif %}
        {% if usedClasses|length %}
        <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
          <th class="text-left p-2 align-top">Uses</th>
          <td class="p-2">{{ usedClasses|sort|join('<br>')|raw }}</td>
        </tr>
        {% endif %}
        {% if class.get('usedBy').getValue()|length %}
          <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
            <th class="text-left p-2 align-top">Used by</th>
            <td class="p-2">{{ class.get('usedBy').getValue()|sort|join('<br>')|raw }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
    {% else %}
      <p class="font-semibold">No dependencies found.</p>
    {% endif %}
  </div>

  {% include('@Parts/divider.html.twig') %}

  <div class="my-8 grid sm:grid-cols-3 gap-3">
    {% for metricKey in detailMetricKeys %}
      {% set element = class.get(metricKey) %}
      {% if metricKey == 'package' %}
        {% include('@Parts/package-tile.html.twig') %}
      {% else %}
        {% include('@Parts/metric-tile.html.twig') %}
      {% endif %}
    {% endfor %}
  </div>

  {% set classMethods = methods[class.getIdentifier().__toString()] %}

  {# --- Visual Charts: Heatmap + Radar --- #}
  {% if classMethods|length > 0 %}
  <div style="display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      {# Method Complexity Heatmap #}
      <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
        <h3 class="mb-3 text-lg font-semibold font-display" style="color: rgba(6,182,212,0.7); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; font-family: 'Oswald', sans-serif;">Method Complexity</h3>
        <div style="position: relative; height: 250px;">
          <canvas id="methodHeatmap"></canvas>
        </div>
      </div>

      {# Class Profile Radar #}
      <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
        <h3 class="mb-3 text-lg font-semibold font-display" style="color: rgba(6,182,212,0.7); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; font-family: 'Oswald', sans-serif;">Class Profile</h3>
        <div style="position: relative; height: 250px;">
          <canvas id="classRadar"></canvas>
        </div>
      </div>
    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    const gridColor = isLight ? 'rgba(0,0,0,0.08)' : 'rgba(255,255,255,0.03)';
    Chart.defaults.color = isLight ? '#475569' : 'rgba(255,255,255,0.5)';
    Chart.defaults.borderColor = isLight ? 'rgba(0,0,0,0.06)' : 'rgba(255,255,255,0.05)';
    Chart.defaults.font.family = "'Source Sans 3', sans-serif";

    // --- Method Complexity Heatmap (Bar Chart) ---
    const methodNames = [
      {% for method in classMethods %}'{{ method.get('singleName').getValue()|default(method.getName())|e('js') }}'{% if not loop.last %},{% endif %}{% endfor %}
    ];
    const methodCC = [
      {% for method in classMethods %}{{ method.get('cc').getValue()|default(0) }}{% if not loop.last %},{% endif %}{% endfor %}
    ];
    const methodLOC = [
      {% for method in classMethods %}{{ method.get('loc').getValue()|default(0) }}{% if not loop.last %},{% endif %}{% endfor %}
    ];

    const ccColors = methodCC.map(cc => {
      if (cc <= 5) return 'rgba(134, 239, 172, 0.8)';
      if (cc <= 10) return 'rgba(253, 230, 138, 0.8)';
      if (cc <= 20) return 'rgba(253, 186, 116, 0.8)';
      return 'rgba(252, 165, 165, 0.8)';
    });

    new Chart(document.getElementById('methodHeatmap'), {
      type: 'bar',
      data: {
        labels: methodNames,
        datasets: [{
          label: 'Cyclomatic Complexity',
          data: methodCC,
          backgroundColor: ccColors,
          borderRadius: 3,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              afterLabel: function(ctx) {
                return 'LOC: ' + methodLOC[ctx.dataIndex];
              }
            }
          }
        },
        scales: {
          x: {
            grid: { color: gridColor },
            ticks: { maxRotation: 45, font: { size: 10 } }
          },
          y: {
            grid: { color: gridColor },
            title: { display: true, text: 'CC', color: '#fde68a' },
            beginAtZero: true,
            ticks: { precision: 0 }
          }
        }
      }
    });

    // --- Class Profile Radar ---
    {% set classCC = class.get('cc').getValue()|default(0) %}
    {% set classLCOM = class.get('lcom').getValue()|default(0) %}
    {% set classLOC = class.get('loc').getValue()|default(0) %}
    {% set classUses = class.get('uses').getValue()|length %}
    {% set classUsedBy = class.get('usedBy').getValue()|length %}

    const radarValues = [{{ classCC }}, {{ classLCOM }}, {{ classLOC }}, {{ classUses }}, {{ classUsedBy }}];
    const radarMax = Math.max(...radarValues, 1);
    const radarNormalized = radarValues.map(v => Math.round((v / radarMax) * 100));

    new Chart(document.getElementById('classRadar'), {
      type: 'radar',
      data: {
        labels: ['CC', 'LCOM', 'LOC', 'Uses', 'Used By'],
        datasets: [{
          label: '{{ class.get('singleName').getValue()|e('js') }}',
          data: radarNormalized,
          borderColor: 'rgb(6, 182, 212)',
          backgroundColor: 'rgba(6, 182, 212, 0.15)',
          borderWidth: 2,
          pointBackgroundColor: 'rgb(6, 182, 212)',
          pointRadius: 4,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                return ctx.label + ': ' + radarValues[ctx.dataIndex];
              }
            }
          }
        },
        scales: {
          r: {
            beginAtZero: true,
            max: 100,
            ticks: { display: false },
            grid: { color: isLight ? 'rgba(0,0,0,0.1)' : 'rgba(255,255,255,0.08)' },
            angleLines: { color: isLight ? 'rgba(0,0,0,0.1)' : 'rgba(255,255,255,0.08)' },
            pointLabels: { color: isLight ? '#334155' : 'rgba(255,255,255,0.7)', font: { size: 12 } }
          }
        }
      }
    });
  });
  </script>
  {% endif %}

  {% if classMethods|length > 0 %}
    {% set folder = 'methods' %}
    {% set tableName = 'Methods' %}
    {% set tableHeaders = methodTableHeaders %}
    {% set listMetricKeys = methodListMetricKeys %}
    {% set functions = methods[class.getIdentifier().__toString()] %}

    {% include('@Parts/divider.html.twig') %}
    {% include('@Parts/function-table.html.twig') %}
  {% endif %}

  {% if interfaces|length or extends|length or usedClasses|length or class.get('usedBy').getValue()|length %}
  {% include('@Parts/divider.html.twig') %}

  <h3 class="mt-8 mb-4 text-2xl font-semibold font-display">Dependency Graph</h3>

  <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-6">
    <div style="display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap;">

      {# Left: incoming dependencies (usedBy) #}
      {% set usedByList = class.get('usedBy').getValue() %}
      {% if usedByList|length %}
      <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end;">
        <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); margin-bottom: 0.25rem;">Used by</div>
        {% for usedByClass in usedByList %}
        <div style="background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); border-radius: 0.375rem; padding: 0.25rem 0.75rem; font-size: 0.8rem; color: #86efac; white-space: nowrap;">
          {{ usedByClass|split('\\')|last }}
        </div>
        {% endfor %}
      </div>
      <div style="color: rgba(34,197,94,0.5); font-size: 1.5rem;">&#x2192;</div>
      {% endif %}

      {# Center: current class #}
      <div style="background: rgba(6,182,212,0.2); border: 2px solid rgb(6,182,212); border-radius: 0.5rem; padding: 1rem 1.5rem; text-align: center; min-width: 120px;">
        <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(6,182,212,0.7); margin-bottom: 0.25rem;">
          {% if class.interface.getValue() %}Interface{% elseif class.trait.getValue() %}Trait{% elseif class.enum.getValue() %}Enum{% elseif class.abstract.getValue() %}Abstract{% else %}Class{% endif %}
        </div>
        <div style="font-family: 'Oswald', sans-serif; font-size: 1.25rem; font-weight: 500;">{{ class.get('singleName') }}</div>
        {% if extends|length %}
        <div style="font-size: 0.7rem; color: rgba(255,255,255,0.5); margin-top: 0.25rem;">
          extends {{ extends|first|split('\\')|last }}
        </div>
        {% endif %}
        {% if interfaces|length %}
        <div style="font-size: 0.7rem; color: rgba(255,255,255,0.5); margin-top: 0.15rem;">
          implements {{ interfaces|map(i => i|split('\\')|last)|join(', ') }}
        </div>
        {% endif %}
      </div>

      {# Right: outgoing dependencies (uses) #}
      {% if usedClasses|length %}
      <div style="color: rgba(251,146,60,0.5); font-size: 1.5rem;">&#x2192;</div>
      <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start;">
        <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); margin-bottom: 0.25rem;">Uses</div>
        {% for usedClass in usedClasses %}
        <div style="background: rgba(251,146,60,0.15); border: 1px solid rgba(251,146,60,0.3); border-radius: 0.375rem; padding: 0.25rem 0.75rem; font-size: 0.8rem; color: #fdba74; white-space: nowrap;">
          {{ usedClass|split('\\')|last }}
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </div>
  </div>
  {% endif %}
</div>

{% include('@Parts/footer.html.twig') %}