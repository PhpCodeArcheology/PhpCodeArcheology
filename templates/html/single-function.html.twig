{% include('@Parts/header.html.twig') %}
{% set metricCollectionId = function.getIdentifier().__toString() %}

{% set isMethod = function.get('functionType').getValue() == 'method' %}
{% set breadCrumbLi = '' %}
{% if isMethod %}
  {% set scope %}
    {% if function.get('public').getValue() %}public{% elseif function.get('protected').getValue() %}protected{% else %}private{% endif %}
    {% if function.get('static').getValue() %}static{% endif %}
  {% endset %}
  {% set breadCrumbLi %}
    <li class="flex after:content-['⮁'] gap-1">
      <a href="../classes-list.html" class="text-cyan-500">Classes</a>
    </li>
    {% if function.get('classInfo').getValue()['namespace'] is defined and function.get('classInfo').getValue()['namespace'] %}
    <li class="flex after:content-['⮁'] gap-1">
      <span class="text-white/50">{{ function.get('classInfo').getValue()['namespace'] }}</span>
    </li>
    {% endif %}
  {% endset %}
{% endif %}
{% set h1Title = isMethod ? 'Method' : 'Function' %}
{% set information = isMethod ? scope : function.get('namespace') %}
{% set functionName = isMethod ? function.getName() : function.get('singleName') %}
{% set divider = isMethod ? ' ' : '/' %}
{% set breadCrumbMiddle = isMethod ? function.get('classInfo').getValue()['singleName'] : 'Functions' %}
{% set breadCrumbLink = isMethod ? 'classes/' ~ function.get('classInfo').getValue()['id'] : 'functions-list' %}

<div class="mt-6 lg:w-5/6">
  <div class="mb-7 text-sm">
    <ul class="flex gap-1">
      <li class="flex after:content-['⮁'] gap-1">
        <a href="../index.html" class="text-cyan-500">Home</a>
      </li>
      {{ breadCrumbLi }}
      <li class="flex after:content-['⮁'] gap-1">
        <a href="../{{ breadCrumbLink }}.html" class="text-cyan-500">{{ breadCrumbMiddle }}</a>
      </li>
      <li>{{ functionName }}</li>
    </ul>
  </div>

  <h1 class="mb-3 text-lg font-semibold font-display">{{ h1Title }} metrics for:</h1>
  <h2 class="mb-6 text-3xl">
    <span class="text-white/40">{{ information }}{{ divider }}</span>
    <span class="font-semibold inline-block" title="{{ information }}{{ divider }}{{ functionName }}">
      {{ functionName }}
    </span>
  </h2>

  {% set docBlockSummary = function.get('docBlockSummary').getValue() %}
  {% if docBlockSummary %}
  <div class="mt-6 rounded-xl border border-white/10 bg-white/5 p-4">
    <p class="text-white/70 leading-relaxed whitespace-pre-line">{{ docBlockSummary }}</p>
  </div>
  {% endif %}

  <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
    <h3 class="mb-3 text-xl font-semibold font-display">Parameters</h3>
    {% set parameters = parameters[function.getIdentifier().__toString()] %}
    {% if parameters|length > 0 %}
      <table>
        <tbody>
        {% for parameter in parameters %}
          <tr>
            <td class="text-white/40 pr-4">{{ parameter.type }}{% if parameter.type is empty %}implicit mixed{% endif %}</td>
            <td class="text-lg font-semibold">{{ parameter.name }}</td>
            <td class="italic text-white/60 pl-4">{{ parameter.description }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="font-semibold">No parameters used</p>
    {% endif %}
  </div>

  <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
    <h3 class="mb-3 text-xl font-semibold font-display">Return type</h3>
    <p class="text-lg font-semibold">{{ function.get('returnType').getValue() }}</p>
  </div>

  <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
    <h3 class="mb-3 text-xl font-semibold font-display">Dependencies</h3>

    {% set dependencies = dependencies[function.getIdentifier().__toString()] %}
    {% if dependencies|length %}
      <table class="w-full border-collapse">
        <tbody>
          <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
            <th class="text-left p-2 align-top">Class dependencies</th>
            <td class="p-2">{{ dependencies|sort|join('<br>')|raw }}</td>
          </tr>
        </tbody>
      </table>
    {% else %}
      <p class="font-semibold">No dependencies found.</p>
    {% endif %}
  </div>

  {% if isMethod %}
    {% set outgoingCalls = methodCalls[metricCollectionId] is defined ? methodCalls[metricCollectionId] : [] %}
    {% set incomingCalls = calledBy[metricCollectionId] is defined ? calledBy[metricCollectionId] : [] %}

    {% if outgoingCalls is not empty or incomingCalls is not empty %}
    <div class="mt-8 rounded-xl border border-cyan-800 bg-cyan-950/45 p-4">
      <h3 class="mb-3 text-xl font-semibold font-display">Method Calls</h3>

      {% if incomingCalls is not empty %}
      <h4 class="mb-2 text-sm font-semibold text-white/50 uppercase tracking-wider">Called by</h4>
      <table class="w-full border-collapse mb-6">
        <thead>
          <tr class="border-b border-white/15">
            <th class="text-left p-2">Class</th>
            <th class="text-left p-2">Method</th>
          </tr>
        </thead>
        <tbody>
          {% for caller in incomingCalls %}
            <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
              <td class="p-2">
                {% if caller.sourceClassId %}
                  <a href="../classes/{{ caller.sourceClassId }}.html" class="text-cyan-500 hover:text-cyan-300">{{ caller.sourceClass }}</a>
                {% else %}
                  <span class="text-white/60">{{ caller.sourceClass }}</span>
                {% endif %}
              </td>
              <td class="p-2">
                {% if caller.sourceMethodId %}
                  <a href="../methods/{{ caller.sourceMethodId }}.html" class="text-cyan-500 hover:text-cyan-300 font-semibold">{{ caller.sourceMethod }}</a>
                {% else %}
                  <span class="font-semibold">{{ caller.sourceMethod }}</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {% if outgoingCalls is not empty %}
      <h4 class="mb-2 text-sm font-semibold text-white/50 uppercase tracking-wider">Calls to</h4>
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-white/15">
            <th class="text-left p-2">Class</th>
            <th class="text-left p-2">Method</th>
          </tr>
        </thead>
        <tbody>
          {% set seen = [] %}
          {% for call in outgoingCalls %}
            {% set callKey = call.targetClass ~ '::' ~ call.targetMethod %}
            {% if callKey not in seen %}
              {% set seen = seen|merge([callKey]) %}
              <tr class="odd:bg-cyan-950/85 even:bg-cyan-950/55 border-t border-white/15">
                <td class="p-2">
                  {% if call.targetClassId %}
                    <a href="../classes/{{ call.targetClassId }}.html" class="text-cyan-500 hover:text-cyan-300">{{ call.targetClass }}</a>
                  {% else %}
                    <span class="text-white/60">{{ call.targetClass }}</span>
                  {% endif %}
                </td>
                <td class="p-2">
                  {% if call.targetMethodId %}
                    <a href="../methods/{{ call.targetMethodId }}.html" class="text-cyan-500 hover:text-cyan-300 font-semibold">{{ call.targetMethod }}</a>
                  {% else %}
                    <span class="font-semibold">{{ call.targetMethod }}</span>
                  {% endif %}
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
      {% endif %}
    </div>
    {% endif %}
  {% endif %}

  {% include('@Parts/divider.html.twig') %}

  <div class="my-8 grid sm:grid-cols-3 gap-3">
    {% set detailMetricKeys = isMethod ? methodDetailMetricKeys : functionDetailMetricKeys %}
    {% for metricKey in detailMetricKeys %}
      {% set element = function.get(metricKey) %}

      {% if metricKey == 'classInfo' %}
        {% include('@Parts/classname-tile.html.twig') %}
      {% else %}
        {% include('@Parts/metric-tile.html.twig') %}
      {% endif %}
    {% endfor %}
  </div>

  {% include('@Parts/source-code.html.twig') %}
</div>

{% include('@Parts/footer.html.twig') %}