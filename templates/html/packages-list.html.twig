{% include('@Parts/header.html.twig') %}

<div class="mt-6 lg:w-5/6">
  <div class="mb-7 text-sm">
    <ul class="flex gap-1">
      <li class="flex after:content-['⮁'] gap-1">
        <a href="index.html" class="text-cyan-500">Home</a>
      </li>
      <li>Packages</li>
    </ul>
  </div>

  <h1 class="mb-6 text-3xl font-semibold font-display">Packages</h1>

  <div style="position: relative; height: 50vh; max-height: 500px; background: rgba(8,51,68,0.2); border-radius: 0.75rem; padding: 1rem; border: 1px solid rgba(6,182,212,0.1);">
    <canvas id="ai-chart"></canvas>
  </div>

  <div class="relative overflow-x-auto">
    <table class="sortable asc my-6 w-full border-collapse border border-slate-500 text-sm rounded-xl transition-opacity" data-currentsort="0:asc:string">
      <thead class="bg-cyan-950/25">
      <tr>
        <th class="border border-slate-500 text-left px-2 py-0.5" data-sortable="string">
            <span class="label-box flex justify-between items-center gap-1">
              <span class="label-name">Package</span>
              <span class="sort-icon transition-all opacity-0"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M12.53 16.28a.75.75 0 0 1-1.06 0l-7.5-7.5a.75.75 0 0 1 1.06-1.06L12 14.69l6.97-6.97a.75.75 0 1 1 1.06 1.06l-7.5 7.5Z" clip-rule="evenodd" /></svg></span>
            </span>
        </th>
        {% for header in tableHeaders %}
          {% include('@Parts/thead-th-sortable.html.twig') %}
        {% endfor %}
      </tr>
      </thead>
      <tbody>
        {% for package in packages %}
          {% set metricCollectionId = package.getIdentifier().__toString() %}
        <tr class="even:bg-cyan-950/45 odd:bg-cyan-950/85 transition-colors hover:bg-cyan-800">
          <td class="border border-slate-500 text-left px-2 py-0.5" data-sort="{{ package.getName() }}">
            <span class="font-semibold inline-block">{{ package.getName() }}</span>
          </td>
          {% for metricKey in listMetricKeys %}
            {% set data = package.get(metricKey) %}

            {% include('@Parts/tbody-td-sortable.html.twig') %}
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const ctx = document.getElementById('ai-chart');
  const xData = {{ aiChart.x|raw }};
  const yData = {{ aiChart.y|raw }};
  const labels = {{ aiChart.count|raw }};

  // Zone background plugin
  const zonePlugin = {
    id: 'zones',
    beforeDraw(chart) {
      const { ctx, chartArea: {left, right, top, bottom, width, height} } = chart;
      const xScale = chart.scales.x;
      const yScale = chart.scales.y;

      function drawZone(path, color) {
        ctx.save();
        ctx.fillStyle = color;
        ctx.beginPath();
        const points = path.map(p => [xScale.getPixelForValue(p[0]), yScale.getPixelForValue(p[1])]);
        ctx.moveTo(points[0][0], points[0][1]);
        for (let i = 1; i < points.length; i++) ctx.lineTo(points[i][0], points[i][1]);
        ctx.closePath();
        ctx.fill();
        ctx.restore();
      }

      // Green: main sequence band
      drawZone([[0,0.75],[0,1],[0.25,1],[1,0.25],[1,0],[0.75,0]], 'rgba(34,197,94,0.08)');
      // Yellow: caution zones
      drawZone([[0,0.4],[0,0.75],[0.75,0],[0.4,0]], 'rgba(234,179,8,0.06)');
      drawZone([[0.25,1],[0.6,1],[1,0.6],[1,0.25]], 'rgba(234,179,8,0.06)');
      // Red: danger zones
      drawZone([[0,0],[0,0.4],[0.4,0]], 'rgba(239,68,68,0.08)');
      drawZone([[0.6,1],[1,1],[1,0.6]], 'rgba(239,68,68,0.08)');

      // Baseline diagonal
      ctx.save();
      ctx.strokeStyle = 'rgba(239,68,68,0.4)';
      ctx.setLineDash([6, 4]);
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(xScale.getPixelForValue(0), yScale.getPixelForValue(1));
      ctx.lineTo(xScale.getPixelForValue(1), yScale.getPixelForValue(0));
      ctx.stroke();
      ctx.restore();

      // Zone labels
      ctx.save();
      ctx.font = "11px 'Source Sans 3', sans-serif";
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.fillText('Zone of Pain', xScale.getPixelForValue(0.02), yScale.getPixelForValue(0.05));
      ctx.fillText('Zone of Uselessness', xScale.getPixelForValue(0.6), yScale.getPixelForValue(0.97));
      ctx.fillStyle = 'rgba(255,255,255,0.15)';
      ctx.fillText('Main Sequence', xScale.getPixelForValue(0.35), yScale.getPixelForValue(0.72));
      ctx.restore();
    }
  };

  new Chart(ctx, {
    type: 'scatter',
    data: {
      datasets: [{
        label: 'Packages',
        data: xData.map((x, i) => ({x: x, y: yData[i]})),
        backgroundColor: 'rgba(6, 182, 212, 0.6)',
        borderColor: 'rgba(6, 182, 212, 0.8)',
        pointRadius: 8,
        pointHoverRadius: 12,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              const idx = ctx.dataIndex;
              return (labels[idx] || '') + ' (I=' + ctx.parsed.x.toFixed(2) + ', A=' + ctx.parsed.y.toFixed(2) + ')';
            }
          }
        }
      },
      scales: {
        x: {
          min: 0, max: 1,
          title: { display: true, text: 'Instability', color: 'rgba(255,255,255,0.5)' },
          grid: { color: 'rgba(255,255,255,0.05)' }
        },
        y: {
          min: 0, max: 1,
          title: { display: true, text: 'Abstractness', color: 'rgba(255,255,255,0.5)' },
          grid: { color: 'rgba(255,255,255,0.05)' }
        }
      }
    },
    plugins: [zonePlugin]
  });
});
</script>

{% include('@Parts/footer.html.twig') %}
