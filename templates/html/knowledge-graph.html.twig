{% include('@Parts/header.html.twig') %}

<style>
  #graph-container {
    position: relative;
    width: 100%;
    height: 700px;
    background: rgba(8,51,68,0.25);
    border: 1px solid rgba(6,182,212,0.15);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .graph-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem 1rem;
    background: rgba(8,51,68,0.35);
    border: 1px solid rgba(6,182,212,0.15);
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
  }
  .graph-tooltip {
    position: absolute;
    background: rgba(8,51,68,0.95);
    border: 1px solid rgba(6,182,212,0.4);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    pointer-events: none;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    display: none;
    max-width: 280px;
  }
  .graph-tooltip-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }
  .graph-tooltip-row {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 0.15rem;
  }
  .graph-tooltip-warn {
    font-size: 0.75rem;
    color: #ef4444;
    margin-top: 0.4rem;
    font-weight: 600;
  }
  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .filter-group-label {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    white-space: nowrap;
  }
  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid;
    cursor: pointer;
    font-size: 0.75rem;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    user-select: none;
  }
  .filter-chip.inactive {
    background: transparent !important;
    color: rgba(255,255,255,0.55) !important;
    border-color: rgba(255,255,255,0.25) !important;
  }
  .filter-chip:hover {
    filter: brightness(1.15);
  }
  .filter-chip:focus-visible {
    outline: 2px solid #06b6d4;
    outline-offset: 2px;
  }
  .graph-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(8,51,68,0.25);
    border: 1px solid rgba(6,182,212,0.1);
    border-radius: 0.5rem;
    margin-top: 1rem;
    font-size: 0.75rem;
  }
  .legend-section {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
  .legend-section-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    margin-right: 0.15rem;
  }
  .legend-node-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .legend-edge-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .legend-line {
    width: 20px;
    height: 2px;
    flex-shrink: 0;
  }
  .legend-hint {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    margin-left: auto;
    white-space: nowrap;
  }
  .cc-slider-label {
    min-width: 1.5rem;
    text-align: center;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
  }
  .reset-zoom-btn {
    padding: 0.2rem 0.65rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(6,182,212,0.3);
    background: rgba(6,182,212,0.1);
    color: rgba(6,182,212,0.9);
    font-size: 0.75rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .reset-zoom-btn:hover {
    background: rgba(6,182,212,0.2);
    border-color: rgba(6,182,212,0.5);
  }
  .problems-only-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.6);
  }
  /* Stats row light-theme tweaks handled via global css overrides */
  [data-theme=light] #graph-container {
    background: #f8fafc;
    border-color: #cbd5e1;
  }
  [data-theme=light] .graph-controls {
    background: #fff;
    border-color: #e2e8f0;
    color: #334155;
  }
  [data-theme=light] .graph-tooltip {
    background: rgba(255,255,255,0.97);
    border-color: #0891b2;
    color: #0f172a;
  }
  [data-theme=light] .graph-tooltip-row {
    color: #475569;
  }
  [data-theme=light] .graph-legend {
    background: #f8fafc;
    border-color: #e2e8f0;
    color: #334155;
  }
  [data-theme=light] .filter-group-label {
    color: #64748b;
  }
  [data-theme=light] .legend-section-label {
    color: #94a3b8;
  }
  [data-theme=light] .legend-hint {
    color: #94a3b8;
  }
  [data-theme=light] .filter-chip.inactive {
    color: #64748b !important;
    border-color: #cbd5e1 !important;
    background: transparent !important;
  }
  [data-theme=light] .filter-chip:focus-visible {
    outline-color: #0891b2;
  }
  [data-theme=light] .problems-only-label {
    color: #475569;
  }
  [data-theme=light] .reset-zoom-btn {
    border-color: #0891b2;
    background: #e0f2fe;
    color: #0e7490;
  }

  /* Focus selector */
  .focus-selector {
    position: relative;
  }
  .focus-search-input {
    width: 220px;
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(6,182,212,0.3);
    background: rgba(8,51,68,0.5);
    color: #fff;
    font-size: 0.75rem;
    font-family: 'Source Sans 3', sans-serif;
    outline: none;
    transition: border-color 0.15s;
  }
  .focus-search-input:focus {
    border-color: rgba(6,182,212,0.7);
  }
  .focus-search-input::placeholder {
    color: rgba(255,255,255,0.4);
  }
  .focus-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 200;
    width: 320px;
    max-height: 300px;
    overflow-y: auto;
    background: rgba(8,51,68,0.97);
    border: 1px solid rgba(6,182,212,0.3);
    border-radius: 0.5rem;
    margin-top: 0.25rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    scrollbar-width: thin;
    scrollbar-color: rgba(6,182,212,0.3) transparent;
  }
  .focus-dropdown.open {
    display: block;
  }
  .focus-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.65rem;
    cursor: pointer;
    font-size: 0.75rem;
    transition: background 0.1s;
    border-bottom: 1px solid rgba(6,182,212,0.06);
  }
  .focus-dropdown-item:hover,
  .focus-dropdown-item.highlighted {
    background: rgba(6,182,212,0.15);
  }
  .focus-dropdown-item.selected {
    background: rgba(6,182,212,0.1);
  }
  .focus-dropdown-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .focus-dropdown-dot[data-type="class"]     { background: #06b6d4; }
  .focus-dropdown-dot[data-type="interface"] { background: #a855f7; }
  .focus-dropdown-dot[data-type="trait"]     { background: #f97316; }
  .focus-dropdown-dot[data-type="package"]   { background: #22c55e; }
  .focus-dropdown-dot[data-type="author"]    { background: #ec4899; }
  .focus-dropdown-item-name {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .focus-dropdown-item-ns {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 140px;
    direction: rtl;
    text-align: left;
  }
  .focus-dropdown-item-check {
    width: 14px;
    text-align: center;
    color: #06b6d4;
    flex-shrink: 0;
  }
  .focus-dropdown-group {
    padding: 0.3rem 0.65rem 0.15rem;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(6,182,212,0.08);
    position: sticky;
    top: 0;
    background: rgba(8,51,68,0.97);
  }
  .focus-dropdown-empty {
    padding: 0.75rem;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 0.75rem;
  }
  .focus-chips {
    display: none;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    background: rgba(8,51,68,0.25);
    border: 1px solid rgba(6,182,212,0.1);
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }
  .focus-chips.has-items {
    display: flex;
  }
  .focus-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.45rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    cursor: default;
    border: 1px solid;
  }
  .focus-chip[data-type="class"]     { border-color: #06b6d4; color: #06b6d4; }
  .focus-chip[data-type="interface"] { border-color: #a855f7; color: #a855f7; }
  .focus-chip[data-type="trait"]     { border-color: #f97316; color: #f97316; }
  .focus-chip[data-type="package"]   { border-color: #22c55e; color: #22c55e; }
  .focus-chip[data-type="author"]    { border-color: #ec4899; color: #ec4899; }
  .focus-chip-remove {
    cursor: pointer;
    opacity: 0.6;
    font-size: 0.85rem;
    line-height: 1;
    margin-left: 0.1rem;
  }
  .focus-chip-remove:hover {
    opacity: 1;
  }

  /* Light theme: focus selector */
  [data-theme=light] .focus-search-input {
    background: #fff;
    border-color: #cbd5e1;
    color: #0f172a;
  }
  [data-theme=light] .focus-search-input::placeholder {
    color: #94a3b8;
  }
  [data-theme=light] .focus-search-input:focus {
    border-color: #0891b2;
  }
  [data-theme=light] .focus-dropdown {
    background: rgba(255,255,255,0.98);
    border-color: #cbd5e1;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  [data-theme=light] .focus-dropdown-item:hover,
  [data-theme=light] .focus-dropdown-item.highlighted {
    background: #e0f2fe;
  }
  [data-theme=light] .focus-dropdown-item-ns {
    color: #94a3b8;
  }
  [data-theme=light] .focus-dropdown-group {
    color: #64748b;
    background: rgba(255,255,255,0.98);
  }
  [data-theme=light] .focus-dropdown-empty {
    color: #94a3b8;
  }
  [data-theme=light] .focus-chips {
    background: #f8fafc;
    border-color: #e2e8f0;
  }
</style>

<div class="mt-6 lg:w-5/6">
  <div class="mb-7 text-sm">
    <ul class="flex gap-1">
      <li class="flex after:content-['⮁'] gap-1">
        <a href="{% if isSubdir %}../{% endif %}index.html" class="text-cyan-500">Home</a>
      </li>
      <li>Knowledge Graph</li>
    </ul>
  </div>

  <h1 class="mb-6 text-3xl font-semibold font-display">Knowledge Graph</h1>

  {# Summary Stats #}
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Nodes</div>
      <div id="stat-nodes" style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500;">—</div>
    </div>
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Edges</div>
      <div id="stat-edges" style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500;">—</div>
    </div>
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Cycles</div>
      <div id="stat-cycles" style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500; color: #ef4444;">—</div>
    </div>
    <div class="rounded-xl border border-cyan-800 bg-cyan-950/45 p-4 text-center">
      <div style="font-size: 0.75rem; color: rgba(255,255,255,0.5);">Packages</div>
      <div id="stat-packages" style="font-family: 'Oswald', sans-serif; font-size: 2.5rem; font-weight: 500;">—</div>
    </div>
  </div>

  {# Filter Controls #}
  <div class="graph-controls">
    <div class="filter-group">
      <span class="filter-group-label">Nodes:</span>
      <span class="filter-chip" data-filter-type="node" data-value="class"     data-color="#0e7490" tabindex="0" role="button">class</span>
      <span class="filter-chip" data-filter-type="node" data-value="interface" data-color="#7c3aed" tabindex="0" role="button">interface</span>
      <span class="filter-chip" data-filter-type="node" data-value="trait"     data-color="#c2410c" tabindex="0" role="button">trait</span>
      <span class="filter-chip" data-filter-type="node" data-value="package"   data-color="#15803d" tabindex="0" role="button">package</span>
      <span class="filter-chip" data-filter-type="node" data-value="author"    data-color="#be185d" tabindex="0" role="button">author</span>
      <span class="filter-chip" data-filter-type="node" data-value="method"    data-color="#64748b" tabindex="0" role="button">method</span>
      <span class="filter-chip inactive" data-filter-type="node" data-value="function" data-color="#475569" tabindex="0" role="button">function</span>
    </div>

    <div class="filter-group">
      <span class="filter-group-label">Edges:</span>
      <span class="filter-chip" data-filter-type="edge" data-value="depends_on"   data-color="#64748b" tabindex="0" role="button">depends_on</span>
      <span class="filter-chip" data-filter-type="edge" data-value="extends"      data-color="#2563eb" tabindex="0" role="button">extends</span>
      <span class="filter-chip" data-filter-type="edge" data-value="implements"   data-color="#7c3aed" tabindex="0" role="button">implements</span>
      <span class="filter-chip" data-filter-type="edge" data-value="uses_trait"   data-color="#c2410c" tabindex="0" role="button">uses_trait</span>
      <span class="filter-chip" data-filter-type="edge" data-value="cycle_member" data-color="#dc2626" tabindex="0" role="button">cycle_member</span>
      <span class="filter-chip inactive" data-filter-type="edge" data-value="belongs_to"  data-color="#64748b" tabindex="0" role="button">belongs_to</span>
      <span class="filter-chip inactive" data-filter-type="edge" data-value="authored_by" data-color="#be185d" tabindex="0" role="button">authored_by</span>
      <span class="filter-chip" data-filter-type="edge" data-value="declares"     data-color="#64748b" tabindex="0" role="button">declares</span>
      <span class="filter-chip" data-filter-type="edge" data-value="calls"        data-color="#a16207" tabindex="0" role="button">calls</span>
    </div>

    <div class="filter-group">
      <span class="filter-group-label">CC-Filter:</span>
      <input type="range" id="cc-filter" min="0" max="50" value="0" style="width:90px; cursor:pointer; accent-color:#06b6d4;">
      <span class="cc-slider-label" id="cc-filter-label">0</span>
    </div>

    <div class="filter-group">
      <label class="problems-only-label">
        <input type="checkbox" id="problems-only" style="accent-color:#ef4444; cursor:pointer;">
        Problems only
      </label>
    </div>

    <div class="filter-group">
      <span class="filter-group-label">Focus:</span>
      <div class="focus-selector">
        <input type="text" id="entity-search" class="focus-search-input"
               placeholder="Search classes or packages..."
               autocomplete="off" role="combobox" aria-expanded="false" aria-controls="entity-dropdown" aria-haspopup="listbox">
        <div class="focus-dropdown" id="entity-dropdown" role="listbox"></div>
      </div>
      <button class="reset-zoom-btn" id="clear-focus">Clear Focus</button>
    </div>

    <div class="filter-group">
      <button class="reset-zoom-btn" id="reset-zoom">Reset Zoom</button>
    </div>
  </div>

  {# Focus chips #}
  <div class="focus-chips" id="focus-chips"></div>

  {# Graph SVG Container #}
  <div id="graph-container">
    <svg id="knowledge-graph-svg" style="width:100%; height:100%;"></svg>
    <div class="graph-tooltip" id="graph-tooltip">
      <div class="graph-tooltip-title" id="tooltip-title"></div>
      <div id="tooltip-body"></div>
    </div>
  </div>

  {# Legend #}
  <div class="graph-legend">
    <div class="legend-section">
      <span class="legend-section-label">Nodes:</span>
      <div class="legend-node-item"><div class="legend-dot" style="background:#06b6d4;"></div><span>class</span></div>
      <div class="legend-node-item"><div class="legend-dot" style="background:#a855f7;"></div><span>interface</span></div>
      <div class="legend-node-item"><div class="legend-dot" style="background:#f97316;"></div><span>trait</span></div>
      <div class="legend-node-item"><div class="legend-dot" style="background:#22c55e;"></div><span>package</span></div>
      <div class="legend-node-item"><div class="legend-dot" style="background:#ec4899;"></div><span>author</span></div>
      <div class="legend-node-item"><div class="legend-dot" style="background:#94a3b8;"></div><span>method</span></div>
      <div class="legend-node-item"><div class="legend-dot" style="background:#64748b;"></div><span>function</span></div>
    </div>
    <div class="legend-section">
      <span class="legend-section-label">Edges:</span>
      <div class="legend-edge-item"><div class="legend-line" style="background:rgba(255,255,255,0.4);"></div><span>depends_on</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:#3b82f6; height:2px;"></div><span>extends</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:#a855f7;"></div><span>implements</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:#f97316;"></div><span>uses_trait</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:#ef4444; height:2px;"></div><span>cycle_member</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:rgba(255,255,255,0.2);"></div><span>belongs_to</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:#ec4899; opacity:0.5;"></div><span>authored_by</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:rgba(255,255,255,0.15);"></div><span>declares</span></div>
      <div class="legend-edge-item"><div class="legend-line" style="background:#facc15; border-style:dashed;"></div><span>calls</span></div>
    </div>
    <div class="legend-hint">Node size = CC &nbsp;|&nbsp; Red border = Cycle &nbsp;|&nbsp; Click = Detail page &nbsp;|&nbsp; Double-click = Focus</div>
  </div>
</div>

<script src="{% if isSubdir %}../{% endif %}assets/js/d3.min.js"></script>
<script src="{% if isSubdir %}../{% endif %}assets/js/knowledge-graph.js"></script>
<script>
  initKnowledgeGraph({{ graphJson|raw }});
</script>

{% include('@Parts/footer.html.twig') %}
