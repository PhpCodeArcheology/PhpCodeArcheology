{
  "name": "php-code-archeology/php-code-archeology",
  "description": "Static analyzer for PHP project archeology. Calculates various metrics for your codebase.",
  "keywords": [
    "analysis",
    "php",
    "static-analysis",
    "code-metrics",
    "complexity",
    "architecture",
    "maintainability",
    "technical-debt",
    "code-quality",
    "mcp",
    "qa",
    "quality"
  ],
  "type": "composer-plugin",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "PhpCodeArch\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Marcus Kober",
      "email": "hello@marcuskober.de",
      "homepage": "https://marcuskober.com",
      "role": "Copyright Holder"
    }
  ],
  "homepage": "https://PhpCodeArcheology.org",
  "support": {
    "issues": "https://github.com/PhpCodeArcheology/PhpCodeArcheology/issues"
  },
  "require-dev": {
    "composer/composer": "^2.0",
    "pestphp/pest": "^3.0",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "rector/rector": "^2.3"
  },
  "extra": {
    "class": "PhpCodeArch\\Composer\\AnalyzePlugin"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-code-archeology/php-code-archeology": true
    },
    "platform": {
      "php": "8.2.0"
    }
  },
  "require": {
    "php": ">=8.2",
    "ext-mbstring": "*",
    "composer-plugin-api": "^2.0",
    "nikic/php-parser": "^5.0",
    "symfony/yaml": "^6.4 || ^7.0 || ^8.0",
    "twig/twig": "^3.0",
    "logiscape/mcp-sdk-php": "^1.5"
  },
  "bin": [
    "bin/phpcodearcheology"
  ],
  "scripts": {
    "post-install-cmd": "git config core.hooksPath .githooks || true",
    "post-update-cmd": "git config core.hooksPath .githooks || true",
    "test": "vendor/bin/pest",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
    "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --allow-risky=yes src/",
    "cs-fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes src/",
    "check": ["@test", "@cs-check", "@analyse"],
    "build-phar": "bash ./scripts/build-phar.sh"
  }
}
