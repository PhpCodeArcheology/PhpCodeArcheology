{
  "name": "html-report",
  "description": "Tailwind CSS build chain for PhpCodeArcheology HTML reports",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./templates/html/assets/css/input.css -o ./templates/html/assets/css/output.css --minify",
    "watch:css": "tailwindcss -i ./templates/html/assets/css/input.css -o ./templates/html/assets/css/output.css --watch"
  },
  "license": "ISC",
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
