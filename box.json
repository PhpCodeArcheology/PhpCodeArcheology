{
    "main": "bin/phpcodearcheology",
    "output": "build/phpcodearcheology.phar",
    "banner": "PhpCodeArcheology — https://phpcodearcheology.org — MIT License",
    "finder": [
        {
            "in": ["src", "data"],
            "name": "*.php"
        },
        {
            "in": ["templates"],
            "name": ["*.twig", "*.css", "*.md", "*.html"]
        },
        {
            "in": ["vendor"],
            "name": "*.php",
            "exclude": [
                "pestphp",
                "phpstan",
                "mockery",
                "rector",
                "friendsofphp"
            ]
        }
    ],
    "compression": "GZ",
    "compactors": [
        "KevinGH\\Box\\Compactor\\Php"
    ],
    "chmod": "0755"
}
