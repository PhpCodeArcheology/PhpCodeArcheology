#!/bin/bash

# Pre-commit hook: Auto-fixes code style on staged PHP files in src/ and tests/.

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(src|tests)/.*\.php$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Running CS Fixer on staged files..."
vendor/bin/php-cs-fixer fix --allow-risky=yes --config=.php-cs-fixer.php --quiet $STAGED_FILES 2>/dev/null

# Re-stage the fixed files
echo "$STAGED_FILES" | xargs git add

exit 0
