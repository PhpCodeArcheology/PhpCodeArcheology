#!/usr/bin/env bash
set -euo pipefail

# PhpCodeArcheology Release Script
# Usage: bin/release [--dry-run] <version>
# Example: bin/release 2.8.0
#          bin/release --dry-run 2.8.0

DRY_RUN=false
VERSION=""

for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        *) VERSION="$arg" ;;
    esac
done

if [[ -z "$VERSION" ]]; then
    echo "Usage: bin/release [--dry-run] <version>"
    echo "Example: bin/release 2.8.0"
    exit 1
fi

if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Error: Version must be in semver format (X.Y.Z), got: $VERSION"
    exit 1
fi

CURRENT=$(grep "CURRENT = " src/Application/Version.php | sed "s/.*'\(.*\)'.*/\1/")
if [[ "$(printf '%s\n' "$CURRENT" "$VERSION" | sort -V | tail -1)" == "$CURRENT" && "$CURRENT" != "$VERSION" ]]; then
    echo "Error: New version $VERSION must be greater than current $CURRENT"
    exit 1
fi

TAG="v$VERSION"
DATE=$(date +%Y-%m-%d)
CHANGELOG="CHANGELOG.md"
VERSION_FILE="src/Application/Version.php"

# Check for uncommitted changes
if [[ -n "$(git status --porcelain -- ':!src/Application/Version.php')" ]]; then
    echo "Error: Working tree has uncommitted changes (besides Version.php). Commit or stash first."
    exit 1
fi

# Check Unreleased section exists and has content
if ! grep -q "## \[Unreleased\]" "$CHANGELOG"; then
    echo "Error: No [Unreleased] section found in $CHANGELOG"
    exit 1
fi

# Extract changelog content between [Unreleased] and the next ## section
RELEASE_NOTES=$(awk '/^## \[Unreleased\]/{found=1; next} /^## \[/{if(found) exit} found{print}' "$CHANGELOG")
RELEASE_NOTES=$(echo "$RELEASE_NOTES" | sed '/^$/N;/^\n$/d' | sed -e '1{/^$/d}' -e '${/^$/d}')

if [[ -z "$RELEASE_NOTES" ]]; then
    echo "Error: [Unreleased] section in $CHANGELOG is empty. Nothing to release."
    exit 1
fi

# Extract first meaningful line for commit message
FIRST_CHANGE=$(echo "$RELEASE_NOTES" | grep -m1 "^- \*\*" | sed 's/^- \*\*\([^*]*\)\*\*.*/\1/' | sed 's/\.$//')

echo "=== Release $TAG ==="
echo "Current version: $CURRENT"
echo "New version:     $VERSION"
echo "Date:            $DATE"
echo "First change:    $FIRST_CHANGE"
echo ""

if $DRY_RUN; then
    echo "[DRY RUN] Would perform the following:"
    echo "  1. Run tests + PHPStan"
    echo "  2. Update Version.php: $CURRENT → $VERSION"
    echo "  3. Update CHANGELOG.md: [Unreleased] → [$VERSION] - $DATE"
    echo "  4. Commit: v$VERSION: $FIRST_CHANGE"
    echo "  5. Tag: $TAG"
    echo "  6. Push to origin"
    echo "  7. Create GitHub release"
    echo ""
    echo "Release notes:"
    echo "$RELEASE_NOTES"
    exit 0
fi

# Run tests
echo "Running tests..."
php vendor/bin/pest --no-progress
echo ""

echo "Running PHPStan..."
php -d memory_limit=1G vendor/bin/phpstan analyse --no-progress
echo ""

# Update Version.php
sed -i '' "s/CURRENT = '.*'/CURRENT = '$VERSION'/" "$VERSION_FILE"
echo "Updated Version.php → $VERSION"

# Update CHANGELOG.md
# Replace [Unreleased] with new version, add empty Unreleased above
sed -i '' "s/## \[Unreleased\]/## [Unreleased]\n\n## [$VERSION] - $DATE/" "$CHANGELOG"
echo "Updated CHANGELOG.md → [$VERSION] - $DATE"

# Commit
git add "$VERSION_FILE" "$CHANGELOG"
git commit -m "$(cat <<EOF
v$VERSION: $FIRST_CHANGE

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
EOF
)"

# Tag
git tag -a "$TAG" -m "v$VERSION: $FIRST_CHANGE"
echo "Created tag $TAG"

# Push
git push origin main --tags
echo "Pushed to origin"

# GitHub Release
gh release create "$TAG" --title "$VERSION" --notes "$RELEASE_NOTES"
echo ""
echo "=== Release $TAG complete ==="
echo "https://github.com/PhpCodeArcheology/PhpCodeArcheology/releases/tag/$TAG"
